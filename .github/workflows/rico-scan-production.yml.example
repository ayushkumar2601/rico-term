# RICO Security Scan - Production Configuration
# 
# This is an example workflow for production use.
# Copy this file to .github/workflows/rico-scan.yml and customize for your needs.
#
# Key differences from demo mode:
# - Uses --fail-on critical to block merges
# - Requires API_URL secret to be configured
# - Fails the build when critical vulnerabilities are found

name: RICO Security Scan (Production)

on:
  pull_request:
    branches: [ main, develop ]
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  security-scan:
    name: API Security Scan
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'
          cache: 'pip'
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -e .
      
      - name: Run RICO Security Scan
        id: rico-scan
        env:
          API_URL: ${{ secrets.API_URL }}
          GROQ_API_KEY: ${{ secrets.GROQ_API_KEY }}
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: |
          echo "🔍 Running RICO security scan..."
          
          # Fail build if critical vulnerabilities are found
          rico report \
            --spec openapi.yaml \
            --url "$API_URL" \
            --output reports \
            --fail-on critical \
            --max-endpoints 10 \
            --ai \
            || echo "SCAN_FAILED=true" >> $GITHUB_ENV
          
          echo "✅ Scan completed"
      
      - name: Upload Security Report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: rico-security-report
          path: reports/
          retention-days: 30
      
      - name: Comment PR with Results
        if: github.event_name == 'pull_request' && always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            
            let reportContent = '## 🔒 RICO Security Scan Results\n\n';
            
            try {
              const report = fs.readFileSync('reports/report.md', 'utf8');
              
              // Extract executive summary
              const summaryMatch = report.match(/## Executive Summary([\s\S]*?)---/);
              if (summaryMatch) {
                reportContent += summaryMatch[1].trim() + '\n\n';
              }
              
              reportContent += '📊 [View Full Report](../actions/runs/${{ github.run_id }})\n\n';
              
              // Check for critical vulnerabilities
              if (report.includes('🔴 Critical:') && !report.includes('🔴 Critical: 0')) {
                reportContent += '❌ **Critical vulnerabilities detected!** This PR cannot be merged until they are fixed.\n';
              } else {
                reportContent += '✅ No critical vulnerabilities detected. Safe to merge.\n';
              }
            } catch (error) {
              reportContent += '❌ Failed to read security report.\n';
            }
            
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: reportContent
            });
      
      - name: Fail build on critical vulnerabilities
        if: env.SCAN_FAILED == 'true'
        run: |
          echo "❌ Critical vulnerabilities detected!"
          echo "Build failed to prevent merging vulnerable code."
          echo "Review the security report and fix critical issues before merging."
          exit 1

# Configuration Notes:
# 
# 1. Required Secrets:
#    - API_URL: Your API endpoint to scan
#    - GROQ_API_KEY or OPENAI_API_KEY: For AI-powered scanning (optional)
#
# 2. Customize the scan:
#    - Change --spec to your OpenAPI spec file path
#    - Adjust --max-endpoints based on your API size
#    - Change --fail-on to 'high' or 'medium' for stricter checks
#    - Add --ai flag to enable AI-powered attack planning
#
# 3. Security Thresholds:
#    - critical: Only fail on critical vulnerabilities (recommended)
#    - high: Fail on high or critical vulnerabilities (strict)
#    - medium: Fail on medium, high, or critical (very strict)
#
# 4. Rate Limiting:
#    - RICO automatically rate limits to 5 req/s
#    - Configure in rico.yaml if needed
