# RICO Configuration File Example
# Copy this file to rico.yaml and configure your settings

# Allowed Domains (Security Feature)
# Only these domains can be scanned
# Leave empty to allow all domains
allowed_domains:
  - localhost
  - 127.0.0.1
  - staging.mycompany.com
  - api.mycompany.com
  # - jsonplaceholder.typicode.com

# Rate Limiting (Prevent DDoS)
rate_limit:
  max_requests_per_second: 5
  max_concurrent_requests: 10

# AI Agent Configuration (Optional)
# Set API keys as environment variables or uncomment below
ai:
  # Groq Configuration (Recommended - Fast & Free)
  # groq_api_key: "gsk-..."
  # groq_model: "llama-3.1-8b-instant"
  
  # OpenAI Configuration
  # openai_api_key: "sk-..."
  # openai_model: "gpt-3.5-turbo"
  
  # Anthropic Claude Configuration
  # anthropic_api_key: "sk-ant-..."
  # anthropic_model: "claude-3-haiku-20240307"
  
  # Provider priority: groq > openai > anthropic
  # Or set AI_PROVIDER environment variable to override
  
  # Enable AI-powered features
  enabled: false

# Testing Configuration
testing:
  # Maximum number of requests per endpoint
  max_requests: 5
  
  # Request timeout in seconds
  timeout: 5
  
  # Maximum endpoints to test (default)
  max_endpoints: 5

# Report Configuration
reports:
  # Output directory for reports
  output_dir: "reports"
  
  # Generate HTML report
  html: true
  
  # Generate Markdown report
  markdown: true

# Security Configuration
security:
  # Minimum confidence threshold to flag vulnerabilities (0-100)
  min_confidence: 60
  
  # Show legal warning before testing
  show_warning: true
